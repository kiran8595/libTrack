<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="512" height="512">
  <rect width="512" height="512" rx="100" fill="#4361ee"/>
  <g transform="translate(256, 256)">
    <!-- Book shape -->
    <rect x="-130" y="-105" width="260" height="210" rx="10" fill="white" opacity="0.9"/>
    <line x1="0" y1="-105" x2="0" y2="105" stroke="#4361ee" stroke-width="5"/>
    <!-- Text lines -->
    <line x1="-80" y1="-65" x2="-20" y2="-65" stroke="#4361ee" stroke-width="8" stroke-linecap="round"/>
    <line x1="-80" y1="-40" x2="-20" y2="-40" stroke="#4361ee" stroke-width="5" stroke-linecap="round" opacity="0.5"/>
    <line x1="-80" y1="-15" x2="-20" y2="-15" stroke="#4361ee" stroke-width="5" stroke-linecap="round" opacity="0.5"/>
    <!-- Pin -->
    <circle cx="90" cy="-55" r="32" fill="#f39c12"/>
    <circle cx="90" cy="-55" r="13" fill="white"/>
  </g>
</svg>
