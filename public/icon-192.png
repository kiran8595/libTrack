<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 192 192" width="192" height="192">
  <rect width="192" height="192" rx="40" fill="#4361ee"/>
  <g transform="translate(96, 96)">
    <!-- Book shape -->
    <rect x="-50" y="-40" width="100" height="80" rx="4" fill="white" opacity="0.9"/>
    <line x1="0" y1="-40" x2="0" y2="40" stroke="#4361ee" stroke-width="2"/>
    <!-- Spine lines -->
    <line x1="-30" y1="-25" x2="-8" y2="-25" stroke="#4361ee" stroke-width="3" stroke-linecap="round"/>
    <line x1="-30" y1="-15" x2="-8" y2="-15" stroke="#4361ee" stroke-width="2" stroke-linecap="round" opacity="0.5"/>
    <line x1="-30" y1="-5" x2="-8" y2="-5" stroke="#4361ee" stroke-width="2" stroke-linecap="round" opacity="0.5"/>
    <!-- Pin -->
    <circle cx="35" cy="-20" r="12" fill="#f39c12"/>
    <circle cx="35" cy="-20" r="5" fill="white"/>
  </g>
</svg>
